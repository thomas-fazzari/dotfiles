{
  // ══════════════════════════════════════════════════════════════
  // Editor Appearance
  // ══════════════════════════════════════════════════════════════
  "editor.fontFamily": "Jetbrains Mono",
  "editor.fontLigatures": true,
  "editor.fontSize": 15,
  "editor.lineHeight": 0,
  "editor.minimap.enabled": false,
  "editor.smoothScrolling": true,
  "editor.cursorBlinking": "solid",
  "editor.cursorSurroundingLines": 8,

  // ══════════════════════════════════════════════════════════════
  // Editor Behavior
  // ══════════════════════════════════════════════════════════════
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.wordWrap": "on",
  "editor.linkedEditing": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.snippetSuggestions": "top",
  "editor.suggestSelection": "first",
  "editor.inlineSuggest.enabled": true,
  "editor.accessibilitySupport": "off",

  // ══════════════════════════════════════════════════════════════
  // Workbench
  // ══════════════════════════════════════════════════════════════
  "workbench.colorTheme": "Aura Dark",
  "workbench.iconTheme": "icons",
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 20,
  "workbench.editor.enablePreview": false,
  "breadcrumbs.enabled": true,

  // ══════════════════════════════════════════════════════════════
  // Files
  // ══════════════════════════════════════════════════════════════
  "files.autoSave": "onFocusChange",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n",
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/*.pyc": true,
    "**/__pycache__": true,
    "**/node_modules": true,
    "**/.pytest_cache": true,
    "**/dist": true,
    "**/.next": true,
    "**/out": true,
    "**/bin": true,
    "**/obj": true,
  },

  // ══════════════════════════════════════════════════════════════
  // Search
  // ══════════════════════════════════════════════════════════════
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.svelte-kit": true,
    "**/bin": true,
    "**/obj": true,
  },

  // ══════════════════════════════════════════════════════════════
  // Explorer
  // ══════════════════════════════════════════════════════════════
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.confirmPasteNative": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "*.cs": "${capture}.designer.cs, ${capture}.g.cs, ${capture}.generated.cs",
    "*.csproj": "${capture}.csproj.user",
    "*.cshtml": "${capture}.cshtml.cs, ${capture}.cshtml.css",
    "*.razor": "${capture}.razor.cs, ${capture}.razor.css",
    "*.resx": "${capture}.Designer.cs",
    "Cargo.toml": "Cargo.lock",
    "go.mod": "go.sum, go.work, go.work.sum",
  },

  // ══════════════════════════════════════════════════════════════
  // Terminal
  // ══════════════════════════════════════════════════════════════
  "terminal.integrated.fontFamily": "MesloLGS NF",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
    },
    "Git Bash": {
      "path": "C:\\Program Files\\Git\\bin\\bash.exe",
      "args": ["--login", "-i"],
    },
  },
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.defaultProfile.osx": "zsh",

  // ══════════════════════════════════════════════════════════════
  // Git
  // ══════════════════════════════════════════════════════════════
  "git.openRepositoryInParentFolders": "always",
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,

  // ══════════════════════════════════════════════════════════════
  // Languages
  // ══════════════════════════════════════════════════════════════

  // JavaScript / TypeScript
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.importModuleSpecifier": "relative",
  "eslint.enable": true,
  "eslint.validate": ["javascript", "typescript", "svelte"],

  // Svelte
  "svelte.enable-ts-plugin": true,
  "emmet.includeLanguages": {
    "svelte": "html",
  },
  "prettier.documentSelectors": ["**/*.svelte"],

  // Python
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "ruff.lint.enable": true,
  "ruff.format.enable": false,

  // Go
  "go.useLanguageServer": true,
  "go.lintTool": "golangci-lint",
  "go.lintFlags": ["--fast"],
  "gopls": {
    "ui.semanticTokens": true,
    "formatting.gofumpt": true,
  },

  // ══════════════════════════════════════════════════════════════
  // Formatters
  // ══════════════════════════════════════════════════════════════
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[svelte]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll": "explicit",
    },
  },
  "[csharp]": {
    "editor.defaultFormatter": "csharpier.csharpier-vscode",
  },
  "[xml]": {
    "editor.defaultFormatter": "csharpier.csharpier-vscode",
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
  },
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format",
  },
  "[swift]": {
    "editor.defaultFormatter": "swiftlang.swift-vscode",
    "editor.tabSize": 4,
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
    },
  },
  "[go.mod]": {
    "editor.defaultFormatter": "golang.go",
  },
  "[lua]": {
    "editor.defaultFormatter": "sumneko.lua",
  },

  // ══════════════════════════════════════════════════════════════
  // Custom Theme
  // ══════════════════════════════════════════════════════════════
  "workbench.colorCustomizations": {
    "editorCursor.foreground": "#569CD6",
    "editor.selectionBackground": "#264F7840",
    "editor.selectionHighlightBackground": "#ADD6FF26",
    "editor.wordHighlightBackground": "#575757B8",
    "editor.findMatchBackground": "#515C6A",
    "editor.findMatchHighlightBackground": "#EA5C0055",
    "editor.lineHighlightBackground": "#ffffff0A",
    "editorLineNumber.activeForeground": "#C6C6C6",
    "editorBracketMatch.background": "#0064001A",
    "editorBracketMatch.border": "#888888",
    "scrollbarSlider.background": "#79797966",
    "scrollbarSlider.hoverBackground": "#646464B3",
    "scrollbarSlider.activeBackground": "#BFBFBF66",
    "statusBar.background": "#121212",
    "statusBar.noFolderBackground": "#121212",
    "statusBar.debuggingBackground": "#121212",
    "statusBar.foreground": "#edecee",
    "statusBar.debuggingForeground": "#edecee",
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": ["comment", "punctuation.definition.comment"],
        "settings": { "foreground": "#6A9955", "fontStyle": "italic" },
      },
      {
        "scope": ["string", "string.quoted"],
        "settings": { "foreground": "#CE9178" },
      },
      {
        "scope": ["keyword", "storage.type", "storage.modifier"],
        "settings": { "foreground": "#569CD6" },
      },
      {
        "scope": ["entity.name.function", "support.function"],
        "settings": { "foreground": "#DCDCAA" },
      },
      {
        "scope": ["variable", "variable.other"],
        "settings": { "foreground": "#9CDCFE" },
      },
      {
        "scope": ["constant.numeric"],
        "settings": { "foreground": "#B5CEA8" },
      },
      {
        "scope": [
          "entity.name.type",
          "entity.name.class",
          "support.type",
          "support.class",
        ],
        "settings": { "foreground": "#4EC9B0" },
      },
      {
        "scope": ["constant.language"],
        "settings": { "foreground": "#569CD6" },
      },
      {
        "scope": ["entity.name.tag"],
        "settings": { "foreground": "#569CD6" },
      },
      {
        "scope": ["entity.other.attribute-name"],
        "settings": { "foreground": "#9CDCFE" },
      },
    ],
  },

  // ══════════════════════════════════════════════════════════════
  // Vim
  // ══════════════════════════════════════════════════════════════
  "vim.leader": "<space>",
  "vim.hlsearch": true,
  "vim.ignorecase": true,
  "vim.smartcase": true,
  "vim.useSystemClipboard": true,
  "vim.easymotion": true,
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.duration": 200,
  "vim.cursorStylePerMode.normal": "block",
  "vim.cursorStylePerMode.insert": "block",

  "vim.handleKeys": {
    "<C-c>": false,
    "<C-v>": false,
    "<C-a>": false,
    "<C-f>": false,
    "<C-p>": false,
    "<C-w>": false,
  },

  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "k"],
      "after": ["<Esc>"],
    },
  ],

  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "s"],
      "commands": ["workbench.action.files.save"],
    },
    {
      "before": ["<leader>", "q"],
      "commands": ["workbench.action.closeActiveEditor"],
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["workbench.action.toggleSidebarVisibility"],
    },
    {
      "before": ["<leader>", "r"],
      "commands": ["editor.action.referenceSearch.trigger"],
    },
    {
      "before": ["<leader>", "d"],
      "commands": ["editor.action.revealDefinition"],
    },
    {
      "before": ["<leader>", "f"],
      "commands": ["workbench.action.quickOpen"],
    },
  ],

  "vim.statusBarColorControl": true,
  "vim.statusBarColors.normal": ["#121212", "#edecee"],
  "vim.statusBarColors.insert": ["#7c3aed", "#edecee"],
  "vim.statusBarColors.visual": ["#22805a", "#edecee"],
  "vim.statusBarColors.visualline": ["#22805a", "#edecee"],
  "vim.statusBarColors.visualblock": ["#22805a", "#edecee"],
  "vim.statusBarColors.replace": ["#ff6767", "#15141b"],
  "vim.statusBarColors.commandlineinprogress": ["#ffca85", "#15141b"],
  "vim.statusBarColors.searchinprogressmode": ["#ffca85", "#15141b"],
  "vim.statusBarColors.easymotionmode": ["#ffca85", "#15141b"],
  "vim.statusBarColors.easymotioninputmode": ["#ffca85", "#15141b"],
  "vim.statusBarColors.surroundinputmode": ["#ffca85", "#15141b"],

  // ══════════════════════════════════════════════════════════════
  // Misc
  // ══════════════════════════════════════════════════════════════
  "telemetry.telemetryLevel": "off",
  "claudeCode.preferredLocation": "panel",
  "fontshortcuts.defaultFontSize": 14,
  "fontshortcuts.defaultTerminalFontSize": 14,
  "fontshortcuts.step": 1,
  "redhat.telemetry.enabled": false,
  "extensions.autoUpdate": false,
  "extensions.autoCheckUpdates": false,
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true,
    "https://ui.shadcn.com": true,
  },
  "makefile.configureOnOpen": false,
}
