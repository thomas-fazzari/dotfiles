{
	// ══════════════════════════════════════════════════════════════
	// Fonts
	// ══════════════════════════════════════════════════════════════
	"editor.fontFamily": "'0xProto Nerd Font'",
	"terminal.integrated.fontFamily": "'0xProto Nerd Font'",
	"terminal.integrated.fontSize": 14,
	"editor.fontSize": 16,
	"editor.fontLigatures": true,
	// ══════════════════════════════════════════════════════════════
	// Editor Appearance
	// ══════════════════════════════════════════════════════════════
	"editor.cursorBlinking": "blink",
	"editor.cursorSmoothCaretAnimation": "off",
	"editor.cursorSurroundingLines": 6,
	"editor.cursorWidth": 2,
	"editor.letterSpacing": 0.3,
	"editor.lineHeight": 22,
	"editor.lineNumbers": "off",
	"editor.renderLineHighlight": "gutter",
	"editor.minimap.enabled": false,
	"editor.stickyScroll.enabled": false,
	"editor.smoothScrolling": false,
	"editor.fastScrollSensitivity": 5,
	// ══════════════════════════════════════════════════════════════
	// Editor Behavior
	// ══════════════════════════════════════════════════════════════
	"editor.formatOnPaste": true,
	"editor.formatOnSave": true,
	"editor.formatOnSaveMode": "modificationsIfAvailable",
	"editor.multiCursorModifier": "ctrlCmd",
	"editor.tabSize": 2,
	"editor.wordWrap": "on",
	"editor.linkedEditing": true,
	"editor.snippetSuggestions": "top",
	"editor.suggestSelection": "first",
	"editor.accessibilitySupport": "off",
	// ══════════════════════════════════════════════════════════════
	// Workbench
	// ══════════════════════════════════════════════════════════════
	"workbench.colorTheme": "Eclipsa",
	"workbench.iconTheme": "a-file-icon-vscode",
	"workbench.productIconTheme": "feather-vscode",
	"workbench.colorCustomizations": {
		"focusBorder": "#2d365c",
		"selection.background": "#2d3b63",
		"editor.background": "#111426",
		"editorGutter.background": "#0f1222",
		"editorGroup.emptyBackground": "#111426",
		"editorGroup.border": "#242b49",
		"editorGroupHeader.tabsBackground": "#0d1020",
		"editorGroupHeader.noTabsBackground": "#111426",
		"editorGroupHeader.tabsBorder": "#242b49",
		"editorWidget.background": "#171b2f",
		"editorHoverWidget.background": "#171b2f",
		"editorHoverWidget.border": "#2d365c",
		"editorSuggestWidget.background": "#171b2f",
		"editorSuggestWidget.border": "#2d365c",
		"editorSuggestWidget.selectedBackground": "#27335a",
		"editor.lineHighlightBackground": "#ffffff08",
		"editor.selectionBackground": "#2d3b63",
		"editor.inactiveSelectionBackground": "#1d2746",
		"editor.findMatchBackground": "#2d3b63",
		"editor.findRangeHighlightBackground": "#242b49",
		"sideBar.background": "#0d1020",
		"sideBar.border": "#242b49",
		"sideBar.dropBackground": "#27335a",
		"sideBarSectionHeader.background": "#00000000",
		"sideBarSectionHeader.border": "#2d365c",
		"activityBar.background": "#0d1020",
		"activityBar.activeBackground": "#242b49",
		"activityBar.border": "#242b49",
		"activityBarBadge.background": "#7bb1e0",
		"titleBar.activeBackground": "#0d1020",
		"titleBar.inactiveBackground": "#0d1020",
		"titleBar.border": "#242b49",
		"statusBar.background": "#14182b",
		"statusBar.border": "#242b49",
		"statusBar.noFolderBackground": "#0d1020",
		"statusBar.debuggingBackground": "#242b49",
		"statusBarItem.hoverBackground": "#ffffff18",
		"tab.activeBackground": "#111426",
		"tab.inactiveBackground": "#0d1020",
		"tab.hoverBackground": "#242b49",
		"tab.border": "#242b49",
		"panel.background": "#111426",
		"panel.border": "#242b49",
		"panelSection.border": "#242b49",
		"panelTitle.activeBorder": "#7bb1e0",
		"terminal.background": "#101424",
		"terminal.border": "#242b49",
		"terminal.selectionBackground": "#2d3b63",
		"input.background": "#0d1020",
		"input.border": "#00000000",
		"dropdown.background": "#0d1020",
		"dropdown.border": "#00000000",
		"quickInput.background": "#171b2f",
		"quickInputTitle.background": "#0d1020",
		"pickerGroup.border": "#2d365c",
		"list.activeSelectionBackground": "#7bb1e018",
		"list.inactiveSelectionBackground": "#7bb1e010",
		"list.focusBackground": "#7bb1e010",
		"list.hoverBackground": "#ffffff08",
		"tree.indentGuidesStroke": "#2d365c",
		"menu.background": "#111426",
		"menu.border": "#2d365c",
		"menu.selectionBackground": "#242b49",
		"menubar.selectionBackground": "#242b49",
		"notifications.background": "#171b2f",
		"notifications.border": "#2d365c",
		"notificationCenterHeader.background": "#0d1020",
		"notificationToast.border": "#2d365c",
		"breadcrumb.background": "#111426",
		"minimap.background": "#111426",
		"scrollbarSlider.background": "#27335a99",
		"scrollbarSlider.hoverBackground": "#2d3b63cc",
		"scrollbarSlider.activeBackground": "#3a4975",
		"tab.activeModifiedBorder": "#7bb1e0",
		"diffEditor.insertedLineBackground": "#5dc9dc10",
		"diffEditor.removedLineBackground": "#c55c9210",
		"diffEditor.insertedTextBackground": "#5dc9dc18",
		"diffEditor.removedTextBackground": "#c55c9218",
		"diffEditor.insertedTextBorder": "#00000000",
		"diffEditor.removedTextBorder": "#00000000",
		"diffEditorGutter.insertedLineBackground": "#00000000",
		"diffEditorGutter.removedLineBackground": "#00000000"
	},
	"workbench.editor.showTabs": "none",
	"workbench.tree.renderIndentGuides": "always",
	"workbench.tree.indent": 22,
	"workbench.browser.showInTitleBar": false,
	"workbench.editor.editorActionsLocation": "hidden",
	"workbench.layoutControl.enabled": false,
	"breadcrumbs.enabled": false,
	"workbench.startupEditor": "newUntitledFile",
	"workbench.editor.enablePreview": false,
	"workbench.settings.editor": "json",
	"window.commandCenter": false,
	"window.closeWhenEmpty": false,

	"workbench.activityBar.location": "bottom",
	// ══════════════════════════════════════════════════════════════
	// Files
	// ══════════════════════════════════════════════════════════════
	"files.autoSave": "afterDelay",
	"files.autoSaveDelay": 2000,
	"files.trimTrailingWhitespace": true,
	"files.insertFinalNewline": true,
	"files.eol": "\n",
	"files.exclude": {
		"**/.DS_Store": true,
		"**/.git": true,
		"**/.idea": true,
		"**/.vs": true,
		"**/*.pyc": true,
		"**/__pycache__": true,
		"**/node_modules": true,
		"**/.pytest_cache": true,
		"**/.ruff_cache": true,
		"**/.mypy_cache": true,
		"**/dist": true,
		"**/build": true,
		"**/.next": true,
		"**/.svelte-kit": true,
		"**/.turbo": true,
		"**/.vite": true,
		"**/.cache": true,
		"**/.parcel-cache": true,
		"**/.angular": true,
		"**/.nuxt": true,
		"**/.output": true,
		"**/out": true,
		"**/bin": true,
		"**/obj": true,
		"**/target": true,
		"**/coverage": true,
		"**/TestResults": true,
		"**/BenchmarkDotNet.Artifacts": true,
		"**/DerivedData": true,
		"**/xcuserdata": true,
		"**/*.tsbuildinfo": true,
		"**/.eslintcache": true,
		"**/lcov.info": true,
		"**/coverage.xml": true,
		"**/*.DotSettings.user": true,
		"**/*.suo": true
	},
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/.idea/**": true,
		"**/.vs/**": true,
		"**/node_modules/**": true,
		"**/dist/**": true,
		"**/build/**": true,
		"**/out/**": true,
		"**/.next/**": true,
		"**/.svelte-kit/**": true,
		"**/.turbo/**": true,
		"**/.vite/**": true,
		"**/.cache/**": true,
		"**/.parcel-cache/**": true,
		"**/.angular/**": true,
		"**/.nuxt/**": true,
		"**/.output/**": true,
		"**/.venv/**": true,
		"**/.pytest_cache/**": true,
		"**/.ruff_cache/**": true,
		"**/.mypy_cache/**": true,
		"**/__pycache__/**": true,
		"**/bin/**": true,
		"**/obj/**": true,
		"**/target/**": true,
		"**/coverage/**": true,
		"**/TestResults/**": true,
		"**/BenchmarkDotNet.Artifacts/**": true,
		"**/DerivedData/**": true,
		"**/xcuserdata/**": true
	},
	// ══════════════════════════════════════════════════════════════
	// Search
	// ══════════════════════════════════════════════════════════════
	"search.exclude": {
		"**/.git": true,
		"**/.idea": true,
		"**/.vs": true,
		"**/node_modules": true,
		"**/dist": true,
		"**/build": true,
		"**/out": true,
		"**/.next": true,
		"**/.svelte-kit": true,
		"**/.turbo": true,
		"**/.vite": true,
		"**/.cache": true,
		"**/.parcel-cache": true,
		"**/.angular": true,
		"**/.nuxt": true,
		"**/.output": true,
		"**/.venv": true,
		"**/.pytest_cache": true,
		"**/.ruff_cache": true,
		"**/.mypy_cache": true,
		"**/__pycache__": true,
		"**/bin": true,
		"**/obj": true,
		"**/target": true,
		"**/coverage": true,
		"**/TestResults": true,
		"**/BenchmarkDotNet.Artifacts": true,
		"**/DerivedData": true,
		"**/xcuserdata": true,
		"**/*.lock": true,
		"**/package-lock.json": true,
		"**/*.pyc": true,
		"**/*.tsbuildinfo": true,
		"**/.eslintcache": true,
		"**/lcov.info": true,
		"**/coverage.xml": true,
		"**/*.DotSettings.user": true,
		"**/*.suo": true
	},
	"search.followSymlinks": false,
	"search.smartCase": true,
	// ══════════════════════════════════════════════════════════════
	// Explorer
	// ══════════════════════════════════════════════════════════════
	"explorer.confirmDragAndDrop": false,
	"explorer.confirmDelete": false,
	"explorer.confirmPasteNative": false,
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.expand": false,
	"explorer.fileNesting.patterns": {
		"*.ts": "${capture}.js",
		"*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
		"*.jsx": "${capture}.js",
		"*.tsx": "${capture}.ts",
		"tsconfig.json": "tsconfig.*.json",
		"package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
		"*.cs": "${capture}.designer.cs, ${capture}.g.cs, ${capture}.generated.cs",
		"*.csproj": "${capture}.csproj.user",
		"*.cshtml": "${capture}.cshtml.cs, ${capture}.cshtml.css",
		"*.razor": "${capture}.razor.cs, ${capture}.razor.css",
		"*.resx": "${capture}.Designer.cs",
		"Cargo.toml": "Cargo.lock",
		"go.mod": "go.sum, go.work, go.work.sum"
	},
	// ══════════════════════════════════════════════════════════════
	// Terminal
	// ══════════════════════════════════════════════════════════════
	"terminal.integrated.smoothScrolling": false,
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.enableMultiLinePasteWarning": "never",
	"terminal.integrated.defaultProfile.osx": "zsh",
	// ══════════════════════════════════════════════════════════════
	// Git
	// ══════════════════════════════════════════════════════════════
	"git.openRepositoryInParentFolders": "always",
	"git.autofetch": false,
	"git.confirmSync": false,
	"git.enableSmartCommit": true,
	// ══════════════════════════════════════════════════════════════
	// Languages
	// ══════════════════════════════════════════════════════════════
	// JavaScript / TypeScript
	"biome.lsp.bin": "biome",
	// Svelte
	"svelte.enable-ts-plugin": true,
	"svelte.plugin.svelte.runesLegacyModeCodeLens.enable": true,
	"emmet.includeLanguages": {
		"svelte": "html"
	},
	// Python
	"python.analysis.typeCheckingMode": "basic",
	"python.analysis.autoImportCompletions": true,
	"ruff.lint.enable": true,
	// Crystal
	"crystal-lang.compiler": "crystal",
	// Go
	"go.lintTool": "golangci-lint",
	"go.lintFlags": ["--fast"],
	"go.toolsManagement.autoUpdate": true,
	"gopls": {
		"ui.semanticTokens": true,
		"formatting.gofumpt": true
	},
	// ══════════════════════════════════════════════════════════════
	// Formatters
	// ══════════════════════════════════════════════════════════════
	"editor.defaultFormatter": "biomejs.biome",
	"resharper.region.region": "Europe",
	"resharper.dataSharing.allowDataSharing": false,
	"resharper.trace.server": "off",
	"resharper.build.useResharperBuild": true,
	"resharper.build.outputVerbosityLevel": "Quiet",
	"resharper.build.restorePackagesOnBuild": false,
	"resharper.build.smartNugetRestore": true,
	"resharper.completion.fullCompletionListWaitTime": 50,
	"resharper.completion.preLoadItemCount": 0,
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"quickfix.biome": "explicit",
			"source.organizeImports.biome": "explicit"
		}
	},
	"[javascriptreact]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"quickfix.biome": "explicit",
			"source.organizeImports.biome": "explicit"
		}
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"quickfix.biome": "explicit",
			"source.organizeImports.biome": "explicit"
		}
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"quickfix.biome": "explicit",
			"source.organizeImports.biome": "explicit"
		}
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[python]": {
		"editor.defaultFormatter": "charliermarsh.ruff",
		"editor.codeActionsOnSave": {
			"source.organizeImports": "always",
			"source.fixAll": "always"
		}
	},
	"[csharp]": {
		"editor.defaultFormatter": "csharpier.csharpier-vscode"
	},
	"[aspnetcorerazor]": {
		"editor.defaultFormatter": "ms-dotnettools.csharp"
	},
	"[xml]": {
		"editor.defaultFormatter": "csharpier.csharpier-vscode"
	},
	"[axaml]": {
		"editor.defaultFormatter": "dabbinavo.xamlstyler"
	},
	"[toml]": {
		"editor.defaultFormatter": "tamasfe.even-better-toml"
	},
	"[go]": {
		"editor.defaultFormatter": "golang.go",
		"editor.tabSize": 4,
		"editor.codeActionsOnSave": {
			"source.organizeImports": "always"
		}
	},
	"[go.mod]": {
		"editor.defaultFormatter": "golang.go"
	},
	"[lua]": {
		"editor.defaultFormatter": "sumneko.lua"
	},
	"[svelte]": {
		"editor.defaultFormatter": "svelte.svelte-vscode"
	},
	"[crystal]": {
		"editor.defaultFormatter": "crystal-lang-tools.crystal-lang",
		"editor.formatOnSave": true
	},
	"[instructions]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[markdown]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[github-actions-workflow]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[skill]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	// ══════════════════════════════════════════════════════════════
	// Vim
	// ══════════════════════════════════════════════════════════════
	"vim.leader": "<space>",
	"vim.hlsearch": true,
	"vim.ignorecase": true,
	"vim.smartcase": true,
	"vim.useSystemClipboard": true,
	"vim.easymotion": true,
	"vim.highlightedyank.enable": true,
	"vim.highlightedyank.duration": 200,
	"vim.cursorStylePerMode.normal": "block",
	"vim.cursorStylePerMode.insert": "block",
	"vim.handleKeys": {
		"<C-c>": false,
		"<C-v>": false,
		"<C-a>": false,
		"<C-f>": false,
		"<C-p>": false,
		"<C-w>": false,
		"<C-t>": false,
		"<D-t>": false
	},
	"vim.insertModeKeyBindings": [
		{
			"before": ["j", "k"],
			"after": ["<Esc>"]
		}
	],
	"vim.normalModeKeyBindingsNonRecursive": [
		{
			"before": ["<leader>", "s"],
			"commands": ["workbench.action.files.save"]
		},
		{
			"before": ["<leader>", "q"],
			"commands": ["workbench.action.closeActiveEditor"]
		},
		{
			"before": ["<leader>", "e"],
			"commands": ["workbench.action.toggleSidebarVisibility"]
		},
		{
			"before": ["<leader>", "r"],
			"commands": ["editor.action.referenceSearch.trigger"]
		},
		{
			"before": ["<leader>", "d"],
			"commands": ["editor.action.revealDefinition"]
		},
		{
			"before": ["<leader>", "p"],
			"commands": ["workbench.action.quickOpen"]
		}
	],
	// ══════════════════════════════════════════════════════════════
	// Misc
	// ══════════════════════════════════════════════════════════════
	"telemetry.telemetryLevel": "off",
	"extensions.autoUpdate": false,
	"extensions.autoCheckUpdates": false,
	"gitlens.ai.model": "vscode",
	"gitlens.ai.vscode.model": "copilot:gpt-4.1",
	"makefile.configureOnOpen": false,
	"biome.suggestInstallingGlobally": false,
	"biome.requireConfiguration": false,
	"json.schemaDownload.trustedDomains": {
		"https://alirezanet.github.io": true,
		"https://biomejs.dev": true,
		"https://developer.microsoft.com/json-schemas/": true,
		"https://json-schema.org/": true,
		"https://json.schemastore.org/": true,
		"https://models.dev/model-schema.json": true,
		"https://opencode.ai": true,
		"https://raw.githubusercontent.com/": true,
		"https://raw.githubusercontent.com/devcontainers/spec/": true,
		"https://raw.githubusercontent.com/microsoft/vscode/": true,
		"https://schemastore.azurewebsites.net/": true,
		"https://ui.shadcn.com": true,
		"https://www.schemastore.org/": true,
		"https://xunit.net": true
	},
	"chat.disableAIFeatures": true
}
