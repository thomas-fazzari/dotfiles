{
	// ══════════════════════════════════════════════════════════════
	// Fonts
	// ══════════════════════════════════════════════════════════════
	"editor.fontFamily": "'Geist Mono'",
	"terminal.integrated.fontFamily": "'MesloLGS Nerd Font'",
	"terminal.integrated.fontSize": 14,
	"editor.fontSize": 16,
	"editor.fontLigatures": true,
	// ══════════════════════════════════════════════════════════════
	// Editor Appearance
	// ══════════════════════════════════════════════════════════════
	"editor.cursorBlinking": "blink",
	"editor.cursorSmoothCaretAnimation": "off",
	"editor.cursorSurroundingLines": 6,
	"editor.cursorWidth": 2,
	"editor.letterSpacing": 0.3,
	"editor.lineHeight": 22,
	"editor.lineNumbers": "on",
	"editor.renderLineHighlight": "gutter",
	"editor.minimap.enabled": false,
	"editor.smoothScrolling": false,
	"editor.fastScrollSensitivity": 5,
	// ══════════════════════════════════════════════════════════════
	// Editor Behavior
	// ══════════════════════════════════════════════════════════════
	"editor.formatOnPaste": true,
	"editor.formatOnSave": true,
	"editor.formatOnSaveMode": "modificationsIfAvailable",
	"editor.multiCursorModifier": "ctrlCmd",
	"editor.tabSize": 2,
	"editor.wordWrap": "on",
	"editor.linkedEditing": true,
	"editor.snippetSuggestions": "top",
	"editor.suggestSelection": "first",
	"editor.accessibilitySupport": "off",
	// ══════════════════════════════════════════════════════════════
	// Workbench
	// ══════════════════════════════════════════════════════════════
	"workbench.settings.editor": "json",
	"workbench.colorTheme": "Tokyo Night Storm Custom",
	"workbench.browser.showInTitleBar": false,
	"workbench.editor.editorActionsLocation": "hidden",
	"workbench.layoutControl.enabled": false,
	"window.commandCenter": false,
	"breadcrumbs.enabled": true,
	"workbench.iconTheme": "a-file-icon-vscode",
	"workbench.productIconTheme": "material-product-icons",
	"workbench.startupEditor": "newUntitledFile",
	"workbench.tree.indent": 20,
	"workbench.activityBar.location": "bottom",
	"workbench.editor.enablePreview": false,
	"workbench.editor.showTabs": "none",
	// ══════════════════════════════════════════════════════════════
	// Files
	// ══════════════════════════════════════════════════════════════
	"files.autoSave": "afterDelay",
	"files.autoSaveDelay": 2000,
	"files.trimTrailingWhitespace": true,
	"files.insertFinalNewline": true,
	"files.eol": "\n",
	"files.exclude": {
		"**/.DS_Store": true,
		"**/*.pyc": true,
		"**/__pycache__": true,
		"**/node_modules": true,
		"**/.pytest_cache": true,
		"**/dist": true,
		"**/.next": true,
		"**/out": true,
		"**/bin": true,
		"**/obj": true
	},
	"files.watcherExclude": {
		"**/node_modules/**": true,
		"**/dist/**": true,
		"**/build/**": true,
		"**/.next/**": true,
		"**/.svelte-kit/**": true,
		"**/.turbo/**": true,
		"**/.venv/**": true,
		"**/bin/**": true,
		"**/obj/**": true,
		"**/target/**": true
	},
	// ══════════════════════════════════════════════════════════════
	// Search
	// ══════════════════════════════════════════════════════════════
	"search.exclude": {
		"**/node_modules": true,
		"**/dist": true,
		"**/build": true,
		"**/.next": true,
		"**/.svelte-kit": true,
		"**/.turbo": true,
		"**/.venv": true,
		"**/bin": true,
		"**/obj": true,
		"**/target": true,
		"**/*.lock": true,
		"**/package-lock.json": true
	},
	"search.followSymlinks": false,
	"search.smartCase": true,
	// ══════════════════════════════════════════════════════════════
	// Explorer
	// ══════════════════════════════════════════════════════════════
	"explorer.confirmDragAndDrop": false,
	"explorer.confirmDelete": false,
	"explorer.confirmPasteNative": false,
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.expand": false,
	"explorer.fileNesting.patterns": {
		"*.ts": "${capture}.js",
		"*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
		"*.jsx": "${capture}.js",
		"*.tsx": "${capture}.ts",
		"tsconfig.json": "tsconfig.*.json",
		"package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
		"*.cs": "${capture}.designer.cs, ${capture}.g.cs, ${capture}.generated.cs",
		"*.csproj": "${capture}.csproj.user",
		"*.cshtml": "${capture}.cshtml.cs, ${capture}.cshtml.css",
		"*.razor": "${capture}.razor.cs, ${capture}.razor.css",
		"*.resx": "${capture}.Designer.cs",
		"Cargo.toml": "Cargo.lock",
		"go.mod": "go.sum, go.work, go.work.sum"
	},
	// ══════════════════════════════════════════════════════════════
	// Terminal
	// ══════════════════════════════════════════════════════════════
	"terminal.integrated.smoothScrolling": false,
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.enableMultiLinePasteWarning": "never",
	"terminal.integrated.profiles.windows": {
		"Debian (WSL)": {
			"source": "Windows Subsystem for Linux",
			"distro": "Debian"
		}
	},
	"terminal.integrated.defaultProfile.windows": "Debian (WSL)",
	"terminal.integrated.defaultProfile.osx": "zsh",
	// ══════════════════════════════════════════════════════════════
	// Git
	// ══════════════════════════════════════════════════════════════
	"git.openRepositoryInParentFolders": "always",
	"git.autofetch": false,
	"git.confirmSync": false,
	"git.enableSmartCommit": true,
	// ══════════════════════════════════════════════════════════════
	// Languages
	// ══════════════════════════════════════════════════════════════
	// JavaScript / TypeScript
	"biome.lsp.bin": "biome",
	// Svelte
	"svelte.enable-ts-plugin": true,
	"svelte.plugin.svelte.runesLegacyModeCodeLens.enable": true,
	"emmet.includeLanguages": {
		"svelte": "html"
	},
	// Python
	"python.analysis.typeCheckingMode": "basic",
	"python.analysis.autoImportCompletions": true,
	"ruff.lint.enable": true,
	// Crystal
	"crystal-lang.compiler": "crystal",
	// Go
	"go.lintTool": "golangci-lint",
	"go.lintFlags": ["--fast"],
	"go.toolsManagement.autoUpdate": true,
	"gopls": {
		"ui.semanticTokens": true,
		"formatting.gofumpt": true
	},
	// ══════════════════════════════════════════════════════════════
	// Formatters
	// ══════════════════════════════════════════════════════════════
	"editor.defaultFormatter": "biomejs.biome",
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"quickfix.biome": "explicit",
			"source.organizeImports.biome": "explicit"
		}
	},
	"[javascriptreact]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"quickfix.biome": "explicit",
			"source.organizeImports.biome": "explicit"
		}
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"quickfix.biome": "explicit",
			"source.organizeImports.biome": "explicit"
		}
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"quickfix.biome": "explicit",
			"source.organizeImports.biome": "explicit"
		}
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[python]": {
		"editor.defaultFormatter": "charliermarsh.ruff",
		"editor.codeActionsOnSave": {
			"source.organizeImports": "always",
			"source.fixAll": "always"
		}
	},
	"[csharp]": {
		"editor.defaultFormatter": "csharpier.csharpier-vscode"
	},
	"[aspnetcorerazor]": {
		"editor.defaultFormatter": "ms-dotnettools.csharp"
	},
	"[xml]": {
		"editor.defaultFormatter": "csharpier.csharpier-vscode"
	},
	"[toml]": {
		"editor.defaultFormatter": "tamasfe.even-better-toml"
	},
	"[go]": {
		"editor.defaultFormatter": "golang.go",
		"editor.tabSize": 4,
		"editor.codeActionsOnSave": {
			"source.organizeImports": "always"
		}
	},
	"[go.mod]": {
		"editor.defaultFormatter": "golang.go"
	},
	"[lua]": {
		"editor.defaultFormatter": "sumneko.lua"
	},
	"[svelte]": {
		"editor.defaultFormatter": "svelte.svelte-vscode"
	},
	"[crystal]": {
		"editor.defaultFormatter": "crystal-lang-tools.crystal-lang",
		"editor.formatOnSave": true
	},
	"[instructions]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[markdown]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[github-actions-workflow]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[skill]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	// ══════════════════════════════════════════════════════════════
	// Vim
	// ══════════════════════════════════════════════════════════════
	"vim.leader": "<space>",
	"vim.hlsearch": true,
	"vim.ignorecase": true,
	"vim.smartcase": true,
	"vim.useSystemClipboard": true,
	"vim.easymotion": true,
	"vim.highlightedyank.enable": true,
	"vim.highlightedyank.duration": 200,
	"vim.cursorStylePerMode.normal": "block",
	"vim.cursorStylePerMode.insert": "block",
	"vim.handleKeys": {
		"<C-c>": false,
		"<C-v>": false,
		"<C-a>": false,
		"<C-f>": false,
		"<C-p>": false,
		"<C-w>": false,
		"<C-t>": false,
		"<D-t>": false
	},
	"vim.insertModeKeyBindings": [
		{
			"before": ["j", "k"],
			"after": ["<Esc>"]
		}
	],
	"vim.normalModeKeyBindingsNonRecursive": [
		{
			"before": ["<leader>", "s"],
			"commands": ["workbench.action.files.save"]
		},
		{
			"before": ["<leader>", "q"],
			"commands": ["workbench.action.closeActiveEditor"]
		},
		{
			"before": ["<leader>", "e"],
			"commands": ["workbench.action.toggleSidebarVisibility"]
		},
		{
			"before": ["<leader>", "r"],
			"commands": ["editor.action.referenceSearch.trigger"]
		},
		{
			"before": ["<leader>", "d"],
			"commands": ["editor.action.revealDefinition"]
		},
		{
			"before": ["<leader>", "p"],
			"commands": ["workbench.action.quickOpen"]
		}
	],
	"claudeCode.preferredLocation": "panel",
	"gitlens.ai.model": "vscode",
	"gitlens.ai.vscode.model": "copilot:gpt-4.1",
	// ══════════════════════════════════════════════════════════════
	// Misc
	// ══════════════════════════════════════════════════════════════
	"telemetry.telemetryLevel": "off",
	"extensions.autoUpdate": false,
	"extensions.autoCheckUpdates": false,
	"makefile.configureOnOpen": false,
	"biome.suggestInstallingGlobally": false,
	"biome.requireConfiguration": false,
	"json.schemaDownload.trustedDomains": {
		"https://alirezanet.github.io": true,
		"https://biomejs.dev": true,
		"https://developer.microsoft.com/json-schemas/": true,
		"https://json-schema.org/": true,
		"https://json.schemastore.org/": true,
		"https://models.dev/model-schema.json": true,
		"https://opencode.ai": true,
		"https://raw.githubusercontent.com/": true,
		"https://raw.githubusercontent.com/devcontainers/spec/": true,
		"https://raw.githubusercontent.com/microsoft/vscode/": true,
		"https://schemastore.azurewebsites.net/": true,
		"https://ui.shadcn.com": true,
		"https://www.schemastore.org/": true,
		"https://xunit.net": true
	},
	"chat.viewSessions.orientation": "stacked",
	"chat.tools.urls.autoApprove": {
		"https://code.visualstudio.com": true,
		"https://github.com/microsoft/vscode/wiki/*": true,
		"https://learn.microsoft.com": true,
		"https://react.dev": true,
		"https://vite.dev": true,
		"https://context7.com/docs/resources": true,
		"https://context7.com/docs": true,
		"https://context7.com": true,
		"https://opencode.ai": {
			"approveRequest": true,
			"approveResponse": true
		}
	},
	"chat.instructionsFilesLocations": {
		".github/": true,
		"~/.config/opencode/": true
	},
	"chat.includeApplyingInstructions": true,
	"chat.tools.terminal.autoApprove": {
		"qmd": true,
		"rg": true,
		"fd": true,
		"fzf": true,
		"jq": true,
		"bat": true,
		"pwd": true
	}
}
