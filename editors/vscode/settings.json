{
  // ══════════════════════════════════════════════════════════════
  // Editor Appearance
  // ══════════════════════════════════════════════════════════════
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorSurroundingLines": 15,
  "editor.fontFamily": "SF Mono",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.letterSpacing": 0.3,
  "editor.lineHeight": 25,
  "editor.minimap.enabled": false,
  "editor.smoothScrolling": true,
  "breadcrumbs.enabled": false,
  "fontshortcuts.defaultFontSize": 14,
  "fontshortcuts.defaultTerminalFontSize": 14,
  "fontshortcuts.step": 1,
  // ══════════════════════════════════════════════════════════════
  // Editor Behavior
  // ══════════════════════════════════════════════════════════════
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "modificationsIfAvailable",
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.linkedEditing": true,
  "editor.snippetSuggestions": "top",
  "editor.suggestSelection": "first",
  "editor.accessibilitySupport": "off",
  // ══════════════════════════════════════════════════════════════
  // Workbench
  // ══════════════════════════════════════════════════════════════
  "workbench.colorTheme": "Tokyo Night",
  "workbench.colorCustomizations": {
    "[Tokyo Night]": {
      "terminal.ansiYellow": "#89ddff",
      "terminal.ansiBrightYellow": "#89ddff",
      "editorWarning.foreground": "#7dcfff",
      "editorOverviewRuler.warningForeground": "#7dcfff",
      "list.warningForeground": "#7dcfff",
      "minimap.warningHighlight": "#7dcfff",
      "inputValidation.warningBorder": "#7dcfff",
      "editorLightBulb.foreground": "#7dcfff",
      "editorLightBulbAutoFix.foreground": "#7dcfff",
      "editorBracketHighlight.foreground6": "#bb9af7",
      "editor.findMatchBorder": "#bb9af7",
      "debugTokenExpression.boolean": "#bb9af7",
      "debugTokenExpression.number": "#bb9af7",
      "gitDecoration.conflictingResourceForeground": "#7dcfffcc",
      "charts.yellow": "#bb9af7",
      "charts.orange": "#bb9af7",
      "scmGraph.foreground1": "#bb9af7",
      "scmGraph.foreground2": "#bb9af7",
      "mergeEditor.conflict.unhandledUnfocused.border": "#bb9af788",
      "mergeEditor.conflict.unhandledFocused.border": "#bb9af7b0",
      "mergeEditor.conflict.unhandled.minimapOverViewRuler": "#bb9af7"
    }
  },
  "editor.tokenColorCustomizations": {
    "[Tokyo Night]": {
      "textMateRules": [
        {
          "scope": [
            "constant.language",
            "constant.numeric",
            "constant.other",
            "constant.other.caps",
            "variable.parameter",
            "meta.function.parameter variable",
            "support.type.property-name.json",
            "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json",
            "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json",
            "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json",
            "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json",
            "punctuation.definition.character-class.regexp",
            "support.constant.property-value",
            "meta.property-list meta.at-rule.if",
            "meta.property-list meta.at-rule.else"
          ],
          "settings": {
            "foreground": "#bb9af7"
          }
        },
        {
          "scope": [
            "punctuation.separator.other.crystal",
            "punctuation.separator.inheritance.crystal"
          ],
          "settings": {
            "foreground": "#f7768e"
          }
        },
        {
          "scope": [
            "comment.block.documentation entity.name.tag",
            "comment.block.documentation punctuation.definition.tag"
          ],
          "settings": {
            "foreground": "#565f89",
            "fontStyle": "italic"
          }
        },
        {
          "scope": [
            "entity.name.tag",
            "punctuation.definition.tag"
          ],
          "settings": {
            "foreground": "#7aa2f7"
          }
        },
        {
          "scope": [
            "entity.name.type.cs",
            "entity.name.type.namespace.cs"
          ],
          "settings": {
            "foreground": "#89ddff"
          }
        },
        {
          "scope": [
            "entity.name.variable.property.cs"
          ],
          "settings": {
            "foreground": "#7dcfff"
          }
        }
      ]
    }
  },
  "editor.semanticTokenColorCustomizations": {
    "[Tokyo Night]": {
      "rules": {
        "parameter.declaration": "#bb9af7"
      }
    }
  },
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 20,
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": "none",
  // ══════════════════════════════════════════════════════════════
  // Files
  // ══════════════════════════════════════════════════════════════
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n",
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/*.pyc": true,
    "**/__pycache__": true,
    "**/node_modules": true,
    "**/.pytest_cache": true,
    "**/dist": true,
    "**/.next": true,
    "**/out": true,
    "**/bin": true,
    "**/obj": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.next/**": true
  },
  // ══════════════════════════════════════════════════════════════
  // Search
  // ══════════════════════════════════════════════════════════════
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.svelte-kit": true,
    "**/bin": true,
    "**/obj": true
  },
  // ══════════════════════════════════════════════════════════════
  // Explorer
  // ══════════════════════════════════════════════════════════════
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.confirmPasteNative": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "*.cs": "${capture}.designer.cs, ${capture}.g.cs, ${capture}.generated.cs",
    "*.csproj": "${capture}.csproj.user",
    "*.cshtml": "${capture}.cshtml.cs, ${capture}.cshtml.css",
    "*.razor": "${capture}.razor.cs, ${capture}.razor.css",
    "*.resx": "${capture}.Designer.cs",
    "Cargo.toml": "Cargo.lock",
    "go.mod": "go.sum, go.work, go.work.sum"
  },
  // ══════════════════════════════════════════════════════════════
  // Terminal
  // ══════════════════════════════════════════════════════════════
  "terminal.integrated.fontFamily": "SF Mono",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    },
    "Git Bash": {
      "path": "C:\\Program Files\\Git\\bin\\bash.exe",
      "args": [
        "--login",
        "-i"
      ]
    }
  },
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.defaultProfile.osx": "zsh",
  // ══════════════════════════════════════════════════════════════
  // Git
  // ══════════════════════════════════════════════════════════════
  "git.openRepositoryInParentFolders": "always",
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  // ══════════════════════════════════════════════════════════════
  // Languages
  // ══════════════════════════════════════════════════════════════
  // JavaScript / TypeScript
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.importModuleSpecifier": "relative",
  "eslint.validate": [
    "javascript",
    "typescript",
    "svelte"
  ],
  // Svelte
  "svelte.enable-ts-plugin": true,
  "emmet.includeLanguages": {
    "svelte": "html"
  },
  // Python
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "ruff.lint.enable": true,
  "ruff.format.enable": false,
  // Crystal
  "crystal-lang.compiler": "crystal",
  "crystal-lang.formatter": "crystal",
  "crystal-lang.ameba.enabled": true,
  "crystal-lang.ameba.path": "ameba",
  // Go
  "go.lintTool": "golangci-lint",
  "go.lintFlags": [
    "--fast"
  ],
  "go.toolsManagement.autoUpdate": true,
  "gopls": {
    "ui.semanticTokens": true,
    "formatting.gofumpt": true
  },
  // ══════════════════════════════════════════════════════════════
  // Formatters
  // ══════════════════════════════════════════════════════════════
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.requireConfig": true,
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always",
      "source.fixAll": "always"
    }
  },
  "[csharp]": {
    "editor.defaultFormatter": "csharpier.csharpier-vscode"
  },
  "[aspnetcorerazor]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp"
  },
  "[xml]": {
    "editor.defaultFormatter": "csharpier.csharpier-vscode"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[swift]": {
    "editor.defaultFormatter": null,
    "editor.formatOnSave": false,
    "editor.tabSize": 4
  },
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "\\.swift$",
        "cmd": "swiftformat ${file}"
      }
    ]
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always"
    }
  },
  "[go.mod]": {
    "editor.defaultFormatter": "golang.go"
  },
  "[lua]": {
    "editor.defaultFormatter": "sumneko.lua"
  },
  "[crystal]": {
    "editor.defaultFormatter": "crystal-lang-tools.crystal-lang",
    "editor.formatOnSave": true
  },
  // ══════════════════════════════════════════════════════════════
  // Vim
  // ══════════════════════════════════════════════════════════════
  "vim.leader": "<space>",
  "vim.hlsearch": true,
  "vim.ignorecase": true,
  "vim.smartcase": true,
  "vim.useSystemClipboard": true,
  "vim.easymotion": true,
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.duration": 200,
  "vim.cursorStylePerMode.normal": "block",
  "vim.cursorStylePerMode.insert": "block",
  "vim.handleKeys": {
    "<C-c>": false,
    "<C-v>": false,
    "<C-a>": false,
    "<C-f>": false,
    "<C-p>": false,
    "<C-w>": false,
    "<C-t>": false,
    "<D-t>": false
  },
  "vim.insertModeKeyBindings": [
    {
      "before": [
        "j",
        "k"
      ],
      "after": [
        "<Esc>"
      ]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<leader>",
        "s"
      ],
      "commands": [
        "workbench.action.files.save"
      ]
    },
    {
      "before": [
        "<leader>",
        "q"
      ],
      "commands": [
        "workbench.action.closeActiveEditor"
      ]
    },
    {
      "before": [
        "<leader>",
        "e"
      ],
      "commands": [
        "workbench.action.toggleSidebarVisibility"
      ]
    },
    {
      "before": [
        "<leader>",
        "r"
      ],
      "commands": [
        "editor.action.referenceSearch.trigger"
      ]
    },
    {
      "before": [
        "<leader>",
        "d"
      ],
      "commands": [
        "editor.action.revealDefinition"
      ]
    },
    {
      "before": [
        "<leader>",
        "p"
      ],
      "commands": [
        "workbench.action.quickOpen"
      ]
    }
  ],
  // ══════════════════════════════════════════════════════════════
  // Misc
  // ══════════════════════════════════════════════════════════════
  "telemetry.telemetryLevel": "off",
  "extensions.autoUpdate": true,
  "extensions.autoCheckUpdates": true,
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true,
    "https://ui.shadcn.com": true
  },
  "makefile.configureOnOpen": false,
  "chat.viewSessions.orientation": "stacked",
  "biome.suggestInstallingGlobally": false,
  "claudeCode.preferredLocation": "panel",
  "claudeCode.selectedModel": "opus",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1"
}
