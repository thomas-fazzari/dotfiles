{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"enabled": true,
			"headers": {
				"CONTEXT7_API_KEY": ""
			}
		}
	},
	"autoupdate": "notify",
	"plugin": ["@tarquinen/opencode-dcp@latest"],
	"permission": {
		"bash": {
			"*": "ask",
			"rg": "allow",
			"rg *": "allow",
			"fd": "allow",
			"fd *": "allow",
			"fzf": "allow",
			"fzf *": "allow",
			"jq": "allow",
			"jq *": "allow",
			"bat": "allow",
			"bat *": "allow",
			"pwd": "allow",
			"pwd *": "allow"
		},
		"webfetch": "allow"
	},
	"watcher": {
		"ignore": [
			"**/node_modules/**",
			"**/dist/**",
			"**/build/**",
			"**/.next/**",
			"**/.svelte-kit/**",
			"**/.turbo/**",
			"**/.venv/**",
			"**/bin/**",
			"**/obj/**",
			"**/target/**"
		]
	}
}
